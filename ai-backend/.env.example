# ══════════════════════════════════════════════════════════════════
# insideBi AI Backend – 환경 설정 가이드
# ══════════════════════════════════════════════════════════════════

# ── LLM 백엔드 선택 ──────────────────────────────────────────────
# "sqlcoder" (권장) | "ollama" (범용) | "groq" (레거시) | "openai" (유료)
LLM_PROVIDER=sqlcoder

# ══════════════════════════════════════════════════════════════════
# [로컬 개발] SQLCoder via Ollama — 완전 무료, 인터넷 불필요
# 설치: ollama pull sqlcoder:7b  (4.1GB)
#        또는 더 정확한 버전: ollama pull sqlcoder:15b  (8.4GB, 16GB RAM 필요)
# ══════════════════════════════════════════════════════════════════
SQLCODER_MODE=ollama
SQLCODER_MODEL=sqlcoder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest          # sqlcoder 실패 시 로컬 fallback

# ══════════════════════════════════════════════════════════════════
# [프로덕션 Railway] SQLCoder 전용 프롬프트 + Groq — 무료 티어
#
# 설정 방법:
#   1. https://console.groq.com 무료 가입 → API 키 발급
#   2. Railway Variables에 아래 변수 설정:
#      LLM_PROVIDER=sqlcoder
#      SQLCODER_MODE=groq
#      GROQ_API_KEY=gsk_...
#
# Groq 무료 티어 rate limit (2025):
#   llama-3.3-70b-versatile : 30 RPM / 14,400 RPD
#   llama-3.1-8b-instant    : 30 RPM / 14,400 RPD
#   → rate limit 초과 시 자동으로 8b 모델 전환
# ══════════════════════════════════════════════════════════════════
# SQLCODER_MODE=groq
GROQ_API_KEY=gsk_...
GROQ_MODEL_SQL=llama-3.3-70b-versatile    # Primary: 고정확도 (SQLCoder 7B 능가)
GROQ_MODEL_FB=llama-3.1-8b-instant        # Secondary: rate limit 초과 시 자동 전환

# ══════════════════════════════════════════════════════════════════
# [레거시] 기존 방식 유지 (하위 호환)
# ══════════════════════════════════════════════════════════════════
# LLM_PROVIDER=groq          → Groq + 범용 프롬프트
# LLM_PROVIDER=openai        → OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── 공통 ──────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db
DB_PATH=./db/insidebi.db
ADMIN_PASSWORD=admin1234
